{
  "name": "claude-codex-pet",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5273 --strictPort",
    "build:electron": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json",
    "dev:electron": "npm run build:electron && concurrently -k \"npm run dev\" \"wait-on tcp:5273 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5273 electron .\"",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "build": "npm run build:electron && vite build",
    "start": "electron .",
    "hook:forward": "node scripts/hook-forwarder.js",
    "hook:doctor": "node scripts/hook-doctor.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^39.8.10",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.479.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "wait-on": "^8.0.3"
  }
}
